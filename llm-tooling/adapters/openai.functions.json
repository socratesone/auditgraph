{
  "format": "openai",
  "tools": [
    {
      "name": "ag_diff",
      "description": "Diff two runs.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_a": {
            "type": "string"
          },
          "run_b": {
            "type": "string"
          },
          "root": {
            "type": "string"
          },
          "config": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "ag_export",
