      "parameters": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "depth": {
            "type": "integer"
          },
          "edge_type": {
            "type": "string",
            "description": "Filter by edge type"
          },
          "min_confidence": {
            "type": "number",
            "description": "Minimum confidence threshold"
          },
          "root": {
            "type": "string"
          },
          "config": {
            "type": "string"
          }
        },
        "required": [
